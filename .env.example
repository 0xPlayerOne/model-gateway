# The gateway does not load dotenv files automatically.
# Export these names only when using environment-backed secrets.

# CORE provider profiles in gateway.core.example.toml
# GOOGLE_API_KEY=
# KILOCODE_API_KEY=
# OPENCODE_API_KEY=
# OPENROUTER_API_KEY=
# CEREBRAS_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
# NOUS_PORTAL_API_KEY=
# NVIDIA_NIM_API_KEY=
# GROQ_API_KEY=
# NOVITA_INFRA_KEY=
# ORCAROUTER_API_KEY=

# Additional built-in profiles
# OPENAI_API_KEY=
# FIREWORKS_API_KEY=
# ZAI_API_KEY=

# Secondary provider profiles in gateway.secondary.example.toml
# OLLAMA_API_KEY=
# CLINE_API_KEY=

# Present in the local environment but not mapped to a documented provider:
# GITLAWB_API_GIT=      # Not a documented OpenAI-compatible provider credential.
