# The gateway does not load dotenv files automatically.
# Export these names only when using environment-backed secrets.

# CORE provider profiles in gateway.core.example.toml
# GOOGLE_API_KEY=
# KILOCODE_API_KEY=
# OPENCODE_API_KEY=
# OPENROUTER_API_KEY=
# CEREBRAS_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
# NOUS_PORTAL_API_KEY=
# NVIDIA_NIM_API_KEY=
# GROQ_API_KEY=
# NOVITA_INFRA_KEY=
# ORCAROUTER_API_KEY=

# Additional built-in profiles
# OPENAI_API_KEY=
# FIREWORKS_API_KEY=
# ZAI_API_KEY=

# Present in local environments but not consumed by an OpenAI Chat profile:
# OLLAMA_API_KEY=       # Ollama Cloud uses the native Ollama API.
# CLINE_API_KEY=        # Cline is a client; its service URL is environment-specific.
# GITLAWB_API_GIT=      # Not a documented OpenAI-compatible provider credential.
