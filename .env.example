# The gateway does not load dotenv files itself. The convenience scripts source
# .env.local and export these values before starting the gateway.
# Any recognized provider API key automatically activates that provider; setup
# is not required.

# MODEL_GATEWAY_BIND=127.0.0.1:8008
# MODEL_GATEWAY_LOCAL_BASE_URL=http://127.0.0.1:8000/v1
# MODEL_GATEWAY_LOCAL_MODEL=
# MODEL_GATEWAY_STATE_PATH=$HOME/.config/model-gateway/routing.sqlite3

# Free-models quality bar: filters low-quality, stale, or expensive models
# from /v1/free-models. Set to 0 to disable a filter.
# MODEL_GATEWAY_FREE_QUALITY_MIN_GENERAL=25.0
# MODEL_GATEWAY_FREE_QUALITY_MIN_CODING=35.0
# MODEL_GATEWAY_FREE_QUALITY_MIN_AGENTIC=15.0
# MODEL_GATEWAY_FREE_QUALITY_MAX_AGE_MONTHS=18
# MODEL_GATEWAY_FREE_QUALITY_MAX_INPUT_PRICE=5.0
# MODEL_GATEWAY_FREE_QUALITY_MAX_OUTPUT_PRICE=15.0

# REQUIRED: must add (free API) to use benchmarks for routing.
# ARTIFICIAL_ANALYSIS_API_KEY=

# CORE: highly encouraged providers. good free limits or paid plans.
# See gateway.core.example.toml.
# GOOGLE_API_KEY=
# KILOCODE_API_KEY=
# OLLAMA_API_KEY=
# OPENCODE_API_KEY=
# OPENROUTER_API_KEY=

# SECONDARY: optional, additional free providers, configured after CORE.
# See gateway.secondary.example.toml.
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# NOUS_PORTAL_API_KEY=
# NVIDIA_NIM_API_KEY=
# SILICON_FLOW_API_KEY=

# OPTIONAL PAID: only configure if you have a subscription or credits.
# See gateway.optional.example.toml.
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# FIREWORKS_API_KEY=
# OPENAI_API_KEY=
# ORCAROUTER_API_KEY=
# ZAI_API_KEY=

# Per-provider non-secret billing override example:
# MODEL_GATEWAY_OPENROUTER_BILLING_MODE=free
# OpenCode Zen and Go share OPENCODE_API_KEY but have independent billing modes:
# MODEL_GATEWAY_OPENCODE_ZEN_BILLING_MODE=free
# MODEL_GATEWAY_OPENCODE_GO_BILLING_MODE=subscription
# MODEL_GATEWAY_OPENROUTER_ACCOUNT_SCOPE=project-id
# MODEL_GATEWAY_OPENROUTER_FREE_MODELS=model-a:free,model-b
# MODEL_GATEWAY_OPENROUTER_MODEL_ALLOWLIST=model-a,model-b
# MODEL_GATEWAY_OPENROUTER_MODEL_DENYLIST=model-c
# MODEL_GATEWAY_OPENROUTER_ALLOW_PREVIEW_MODELS=false
# MODEL_GATEWAY_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# MODEL_GATEWAY_OPENROUTER_QUOTAS=requests:1000:86400:utc_day;cost_microusd:500000:2592000:utc_month
